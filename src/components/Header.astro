---
import IconPhone from './IconPhone.astro';
import { url } from '../utils/url.js';
import { site } from '../data/site.js';
const nav = [
  { href: '#spielen', label: 'Spielen' },
  { href: '#events', label: 'Turniere' },
  { href: '#teams', label: 'Teams' },
  { href: '#feiern', label: 'Feiern' },
  { href: '#kontakt', label: 'Kontakt' },
];
---
<header class="hd">
  <div class="container hd__inner">
    <a href="#top" class="hd__brand">
      <img class="hd__mark" src={url('/logo-mark.png')} alt="" width="30" height="30" decoding="async" />
      Dart Lounge <span class="hd__mitte">Mitte</span>
    </a>

    <nav class="hd__nav" aria-label="Hauptmenü">
      {nav.map((n) => <a href={n.href}>{n.label}</a>)}
    </nav>

    <a href={`tel:${site.phoneHref}`} class="btn btn--primary hd__cta">
      <IconPhone /> Anrufen
    </a>

    <button class="hd__burger" aria-label="Menü" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
  <nav class="hd__mobile" aria-label="Menü mobil">
    {nav.map((n) => <a href={n.href}>{n.label}</a>)}
    <a href={`tel:${site.phoneHref}`} class="hd__mobile-call"><IconPhone /> {site.phone}</a>
  </nav>
</header>

<style>
  .hd {
    position: sticky; top: 0; z-index: 50;
    background: rgba(20, 23, 28, .82);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-soft);
  }
  .hd__inner { display: flex; align-items: center; gap: 20px; height: 66px; }
  .hd__brand {
    display: inline-flex; align-items: center; gap: 10px;
    font-weight: 800; font-size: 1.15rem; color: var(--text); letter-spacing: -.02em;
  }
  .hd__brand:hover { text-decoration: none; }
  .hd__mitte { color: var(--accent); }
  .hd__mark { width: 30px; height: 30px; flex: 0 0 auto; }
  .hd__nav { display: flex; gap: 24px; margin-left: auto; }
  .hd__nav a { color: var(--text-soft); font-weight: 600; font-size: .96rem; }
  .hd__nav a:hover { color: var(--accent); text-decoration: none; }
  .hd__cta { margin-left: 4px; }
  .hd__burger { display: none; background: none; border: 0; cursor: pointer; padding: 8px; margin-left: auto; }
  .hd__burger span { display: block; width: 24px; height: 2px; background: var(--text); margin: 5px 0; border-radius: 2px; transition: .2s; }
  .hd__mobile { display: none; flex-direction: column; padding: 8px 22px 18px; gap: 4px; border-top: 1px solid var(--border-soft); }
  .hd__mobile a { color: var(--text-soft); font-weight: 600; padding: 10px 0; }
  .hd__mobile-call { color: var(--accent) !important; display: inline-flex; align-items: center; gap: 9px; }

  @media (max-width: 820px) {
    .hd__nav, .hd__cta { display: none; }
    .hd__burger { display: block; }
    .hd.open .hd__mobile { display: flex; }
    .hd.open .hd__burger span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hd.open .hd__burger span:nth-child(2) { opacity: 0; }
    .hd.open .hd__burger span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  }
</style>

<script>
  const hd = document.querySelector('.hd');
  const burger = hd?.querySelector('.hd__burger');
  burger?.addEventListener('click', () => {
    const open = hd.classList.toggle('open');
    burger.setAttribute('aria-expanded', String(open));
  });
  hd?.querySelectorAll('.hd__mobile a').forEach((a) =>
    a.addEventListener('click', () => hd.classList.remove('open'))
  );
</script>
